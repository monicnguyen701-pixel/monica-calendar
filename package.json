{
  "name": "monica-calendar",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^42.3.0"
  },
  "build": {
    "appId": "com.monica.calendar",
    "win": {
      "icon": "icon.ico"
    },
    "mac": {
      "icon": "icon.icns"
    },
    "linux": {
      "icon": "icon.png"
    }
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "./icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "setupIcon": "./icon.ico"
          }
        },
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "icon": "./icon.icns"
          }
        }
      ]
    }
  }
}
